# ============================================================
# CONFIGURACIÓN DE ALERTAS BITCOIN
# Copia este archivo como .env y rellena tus datos
# ============================================================

# Email donde recibirás las alertas
ALERT_EMAIL=tu_email@ejemplo.com

# Cuenta de Gmail que ENVÍA las alertas
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_cuenta@gmail.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Umbrales Puell Multiple
PUELL_BUY_THRESHOLD=0.5
PUELL_SELL_THRESHOLD=4.0

# Umbrales MVRV Z-Score
MVRV_BUY_THRESHOLD=0.0
MVRV_SELL_THRESHOLD=7.0

# ALWAYS = envía siempre / SIGNAL = solo cuando hay señal
EMAIL_MODE=SIGNAL
